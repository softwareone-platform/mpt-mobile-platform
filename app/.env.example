# Logging Configuration
# Options: debug, info, warn, error (default: info)
# - debug: All logs (debug, info, warn, error)
# - info: Info and above (info, warn, error)
# - warn: Warnings and above (warn, error)
# - error: Errors only
LOG_LEVEL=info

# Auth0 Configuration (Test Environment)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
AUTH0_SCOPE=
AUTH0_API_URL=
AUTH0_OTP_DIGITS=
AUTH0_SCHEME=

# Review Environment for Reviewers (Dynamic Environment Switching)
REVIEW_ENV_AUTH0_DOMAIN=
REVIEW_ENV_AUTH0_CLIENT_ID=
REVIEW_ENV_AUTH0_AUDIENCE=
REVIEW_ENV_AUTH0_API_URL=

# Reviewer Emails (comma-separated, case-insensitive)
REVIEWER_EMAILS=

# Tests (Airtable Configuration for OTP testing)
AIRTABLE_EMAIL=
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=
AIRTABLE_FROM_EMAIL=

# API Configuration (for test data validation)
API_BASE_URL=
API_OPS_TOKEN=
# API token scoped to a Client/Buyer account (same user, client account selected)
# Used for API validation in client-scoped E2E tests (agreements, orders, subscriptions, etc.)
API_CLIENT_TOKEN=
# API token scoped to a Vendor account (optional, only needed for vendor-scoped tests)
API_VENDOR_TOKEN=
# ACC- ID of the Operations account for this environment (used for account switching in E2E tests)
# Default (test env): ACC-4850-1126
OPS_ACCOUNT_ID=
# ACC- ID of the Client/Buyer test account for this environment (used for account switching in E2E tests)
CLIENT_ACCOUNT_ID=

# Application Insights Configuration
APPLICATION_INSIGHTS_CONNECTION_STRING=

# Windows - Zscaler issues when running appium e2e tests
NODE_EXTRA_CA_CERTS=%USERPROFILE%\.zscaler-root-ca.pem
